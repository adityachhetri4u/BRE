# ============================================
# Bharat Resilience Engine — Backend Configuration
# ============================================
# Copy this file to .env and update paths as needed:
#   cp .env.example .env

# --- Server Settings ---
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
PORT=5001
HOST=0.0.0.0

# --- ML Model Paths ---
POWER_MODEL_PATH=models/power_model_v2.pkl
FUEL_MODEL_PATH=models/fuel_xgboost.pkl
FUEL_FEATURES_PATH=models/fuel_feature_names.pkl
WATER_MODEL_PATH=models/water_rf.pkl
WATER_FEATURES_PATH=models/water_feature_names.pkl
CYBER_MODEL_PATH=models/cyber_iso_forest.pkl
CYBER_PREPROCESSOR_PATH=models/cyber_preprocessor.pkl

# --- Data Paths ---
CYBER_DATA_PATH=data/cyber_cleaned_data.csv

# --- CORS ---
CORS_ORIGINS=*
